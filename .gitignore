# Build artifacts - generated by compilation
build/
*.o
*.d
*.elf
*.map
*.lst

# Exception: We DO want binary releases tracked
!binary/
!binary/*.bin

# macOS system files
.DS_Store
.AppleDouble
.LSOverride
._*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
venv/
env/
*.log

# Temporary files
*.tmp
*.bak
*.backup

# Private/Unreleased Projects
# These are version controlled locally but not pushed to GitHub
original-hothouse-projects/tremodulay-hothouse/

# Placeholder for future private ports (uncomment when created)
# funbox-to-hothouse-ports/[future-port-name]/

# Staging folder for docs/files from planning sessions
# Use _incoming/* (not _incoming/) so the .gitkeep exception works —
# git cannot re-include files inside a directory that is itself excluded.
_incoming/*
!_incoming/.gitkeep
